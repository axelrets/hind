# Hind – frontend environment
# Copy to .env and fill in once the Supabase project exists.
# The app runs WITHOUT these (local Swedish seed + canned AI fallback),
# and "lights up" with real data + real voice/AI once they're set.

# Supabase project (Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-anon-publishable-key

# ─────────────────────────────────────────────────────────────
# The OpenAI (Whisper) and Anthropic (Claude) keys do NOT go here.
# They are set as Supabase Edge Function secrets, server-side:
#   supabase secrets set OPENAI_API_KEY=sk-...  ANTHROPIC_API_KEY=sk-ant-...
# (or Dashboard → Edge Functions → Secrets). The browser never sees them.
# ─────────────────────────────────────────────────────────────
